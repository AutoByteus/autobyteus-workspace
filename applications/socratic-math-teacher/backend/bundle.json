{
  "contractVersion": "1",
  "entryModule": "backend/dist/entry.mjs",
  "moduleFormat": "esm",
  "distribution": "self-contained",
  "targetRuntime": {
    "engine": "node",
    "semver": ">=22 <23"
  },
  "sdkCompatibility": {
    "backendDefinitionContractVersion": "1",
    "frontendSdkContractVersion": "1"
  },
  "supportedExposures": {
    "queries": false,
    "commands": false,
    "routes": false,
    "graphql": false,
    "notifications": false,
    "eventHandlers": true
  },
  "migrationsDir": "backend/migrations",
  "assetsDir": "backend/assets"
}
