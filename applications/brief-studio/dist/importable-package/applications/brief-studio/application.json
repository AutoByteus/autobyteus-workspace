{
  "manifestVersion": "3",
  "id": "brief-studio",
  "name": "Brief Studio",
  "description": "External teaching sample with an app-owned GraphQL brief API, durable event projection, and many runs over one brief record.",
  "icon": "ui/icon.svg",
  "ui": {
    "entryHtml": "ui/index.html",
    "frontendSdkContractVersion": "2"
  },
  "backend": {
    "bundleManifest": "backend/bundle.json"
  },
  "resourceSlots": [
    {
      "slotKey": "draftingTeam",
      "name": "Drafting Team",
      "description": "Team resource used when Brief Studio launches a new drafting run.",
      "allowedResourceKinds": ["AGENT_TEAM"],
      "allowedResourceOwners": ["bundle", "shared"],
      "required": true,
      "supportedLaunchDefaults": {
        "runtimeKind": true,
        "llmModelIdentifier": true,
        "workspaceRootPath": true
      },
      "defaultResourceRef": {
        "owner": "bundle",
        "kind": "AGENT_TEAM",
        "localId": "brief-studio-team"
      }
    }
  ]
}
