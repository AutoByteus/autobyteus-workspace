# Docker image tag
AUTOBYTEUS_IMAGE_TAG=latest

# Host-exposed server port (maps to container 8000)
AUTOBYTEUS_BACKEND_PORT=8001

# Host-exposed VNC ports (mapped to container 5900/6080/9223)
AUTOBYTEUS_VNC_PORT=5908
AUTOBYTEUS_WEB_VNC_PORT=6080
AUTOBYTEUS_CHROME_DEBUG_PORT=9228

# Optional: GitHub credentials for runtime sync (set SKIP_SYNC=0 to use)
GITHUB_PAT=
GITHUB_USERNAME=
GITHUB_EMAIL=

# If set to 1, existing local clones are not updated on startup
AUTOBYTEUS_SKIP_SYNC=1

# Runtime settings written into data-dir .env (if missing)
APP_ENV=production
PERSISTENCE_PROVIDER=sqlite
DB_TYPE=sqlite
LOG_LEVEL=INFO
