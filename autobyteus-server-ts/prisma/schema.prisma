generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TokenUsageRecord {
  id             Int      @id @default(autoincrement())
  usageRecordId  String   @unique @default(uuid()) @map("usage_record_id")
  runId          String   @map("agent_id")
  role           String
  tokenCount     Int      @map("token_count")
  cost           Float
  createdAt      DateTime @default(now()) @map("created_at")
  llmModel       String?  @map("llm_model")

  @@map("token_usage_records")
}

model AgentArtifact {
  id            Int      @id @default(autoincrement())
  runId         String   @map("agent_id")
  path          String
  type          String
  workspaceRoot String?  @map("workspace_root")
  url           String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([runId])
  @@map("agent_artifacts")
}


model AppDataMigrationRecord {
  id           Int       @id @default(autoincrement())
  migrationId  String    @unique @map("migration_id")
  displayName  String    @map("display_name")
  status       String
  attempts     Int       @default(0)
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  summaryJson  String?   @map("summary_json")
  errorMessage String?   @map("error_message")
  logPath      String?   @map("log_path")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("app_data_migration_records")
}
