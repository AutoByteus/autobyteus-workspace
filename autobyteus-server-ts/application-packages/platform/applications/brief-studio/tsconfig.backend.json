{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmitOnError": true,
    "rootDir": "backend-src",
    "outDir": ".build/backend"
  },
  "include": [
    "backend-src/**/*.ts"
  ]
}
