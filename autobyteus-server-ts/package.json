{
  "name": "autobyteus-server-ts",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepare:shared": "pnpm -C .. --filter autobyteus-ts --filter @autobyteus/application-sdk-contracts --filter @autobyteus/application-backend-sdk build",
    "prebuild": "pnpm prepare:shared && pnpm exec prisma generate --schema ./prisma/schema.prisma",
    "build": "pnpm run build:full",
    "build:full": "tsc -p tsconfig.build.json && node ./scripts/copy-managed-messaging-assets.mjs && node ./scripts/smoke-default-super-assistant-bootstrap.mjs",
    "pretypecheck": "pnpm prepare:shared",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm prepare:shared",
    "test": "vitest",
    "cleanup:codex-e2e-history": "node ./scripts/cleanup-codex-e2e-run-history.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@autobyteus/application-sdk-contracts": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.22.0",
    "autobyteus-ts": "workspace:*",
    "chokidar": "^4.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^4.29.1",
    "fuzzysort": "^2.0.4",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "ignore": "^7.0.5",
    "mercurius": "^13.1.0",
    "mime-types": "^3.0.2",
    "reflect-metadata": "^0.2.2",
    "repository_prisma": "^1.0.6",
    "type-graphql": "^2.0.0-rc.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.0.10",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.0.18",
    "ws": "^8.18.1"
  },
  "license": "Apache-2.0"
}
