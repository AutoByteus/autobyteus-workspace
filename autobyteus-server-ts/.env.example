# AutoByteus Server default environment template.
# This file is used as a desktop packaging fallback when .env is not present.

APP_ENV=production
LOG_LEVEL=INFO
PRISMA_LOG_QUERIES=0

DB_TYPE=sqlite
DATABASE_URL=file:./db/production.db

AUTOBYTEUS_SERVER_HOST=http://localhost:29695

# Debug tracing for send_message_to relay interception in codex runtime router.
# Set to 0 to disable these logs.
CODEX_SEND_MESSAGE_RELAY_DEBUG=1

# Prisma SQL query logging is off by default to avoid flooding normal server logs.
# Set to 1 only when you explicitly need raw SQL query visibility for troubleshooting.
# PRISMA_LOG_QUERIES=1
