# ---------------------------
# Gateway base configuration
# ---------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8010
GATEWAY_SERVER_BASE_URL=http://host.docker.internal:8000
GATEWAY_SERVER_SHARED_SECRET=replace-with-strong-secret

# Optional admin hardening
GATEWAY_ADMIN_TOKEN=replace-with-admin-token

# Optional provider webhook secrets
# GATEWAY_WHATSAPP_BUSINESS_SECRET=
# GATEWAY_WECOM_WEBHOOK_TOKEN=

# ---------------------------
# WeChat sidecar wiring
# ---------------------------
SIDECAR_PORT=8788

# IMPORTANT:
# This is the shared secret between sidecar and gateway.
# Use a strong random value and keep it identical for both services.
# Example generation command:
#   openssl rand -hex 32
SIDECAR_SHARED_SECRET=replace-with-64-hex-characters

# Sidecar provider selection
# For Linux Docker default, use puppet-service.
WECHATY_PUPPET=wechaty-puppet-service

# Required for wechaty-puppet-service.
WECHATY_PUPPET_SERVICE_TOKEN=replace-with-your-puppet-service-token

# Optional provider options JSON
# WECHATY_PUPPET_OPTIONS_JSON={"token":"replace-with-your-puppet-service-token"}

# Optional puppet service endpoint override
# WECHATY_PUPPET_SERVICE_ENDPOINT=

# Sidecar logging
SIDECAR_LOG_LEVEL=info
SIDECAR_GATEWAY_TIMEOUT_MS=10000
