# Required service wiring
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8010
GATEWAY_SERVER_BASE_URL=http://host.docker.internal:8000
GATEWAY_SERVER_SHARED_SECRET=replace-with-strong-secret

# Optional admin hardening
GATEWAY_ADMIN_TOKEN=replace-with-admin-token

# Optional channel-specific webhook secrets
# GATEWAY_WHATSAPP_BUSINESS_SECRET=
# GATEWAY_WECOM_WEBHOOK_TOKEN=

# Optional personal-session modes
# Keep these roots inside /app/autobyteus-message-gateway/memory so they persist
# via the compose volume mount.
GATEWAY_WHATSAPP_PERSONAL_ENABLED=false
GATEWAY_WHATSAPP_PERSONAL_AUTH_ROOT=/app/autobyteus-message-gateway/memory/whatsapp-personal
GATEWAY_WECHAT_PERSONAL_ENABLED=false
GATEWAY_WECHAT_PERSONAL_STATE_ROOT=/app/autobyteus-message-gateway/memory/wechat-personal
