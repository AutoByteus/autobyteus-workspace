# Sidecar HTTP
SIDECAR_HOST=0.0.0.0
SIDECAR_PORT=8788

# Gateway callback target
# Example: http://localhost:8010
GATEWAY_BASE_URL=http://localhost:8010

# Must match GATEWAY_WECHAT_PERSONAL_SIDECAR_SHARED_SECRET in gateway env
SIDECAR_SHARED_SECRET=CHANGE_ME

# Wechaty provider setup
# Default works with wechaty-puppet-service package
WECHATY_PUPPET=wechaty-puppet-service

# Required for token-based providers (service/padlocal)
# WECHATY_PUPPET_SERVICE_TOKEN=

# Optional provider options JSON; merged with token if provided.
# WECHATY_PUPPET_OPTIONS_JSON={"token":"<token>"}

# Optional: force endpoint for puppet-service style providers
# WECHATY_PUPPET_SERVICE_ENDPOINT=

# Logging level: silly|verbose|info|warn|error
SIDECAR_LOG_LEVEL=info

# Request timeout for gateway callback
SIDECAR_GATEWAY_TIMEOUT_MS=10000
